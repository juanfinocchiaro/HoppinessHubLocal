{
  "name": "@hoppiness/backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --dts",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:migrate:phase2": "tsx src/db/migrations/phase2-promo-channel-config.ts",
    "db:migrate:phase3": "tsx src/db/migrations/phase3-price-list-item-visibility.ts",
    "db:migrate:phase5": "tsx src/db/migrations/phase5-channel-pending-changes.ts",
    "db:migrate:phase6": "tsx src/db/migrations/phase6-menu-item-components.ts",
    "db:migrate:rework-phase2": "tsx src/db/migrations/rework-phase2-cost-rollup-audit.ts",
    "db:migrate:rework-phase3": "tsx src/db/migrations/rework-phase3-visibility-unified.ts",
    "db:migrate:rework-phase6": "tsx src/db/migrations/rework-phase6-menu-snapshot.ts",
    "db:migrate:rework-phase7": "tsx src/db/migrations/rework-phase7-modifier-unification.ts",
    "db:migrate:billing-sprint0": "tsx src/db/migrations/billing-sprint0-tenancy-foundation.ts",
    "db:migrate:billing-sprint1": "tsx src/db/migrations/billing-sprint1-billing-schema.ts",
    "db:migrate:tenancy-s1": "tsx src/db/migrations/migration-tenancy-s1-accounts.ts",
    "db:migrate:tenancy-s2": "tsx src/db/migrations/migration-tenancy-s2-catalog-presence.ts",
    "db:migrate:tenancy-s3": "tsx src/db/migrations/migration-tenancy-s3-permissions.ts",
    "db:migrate:tenancy-s5": "tsx src/db/migrations/migration-tenancy-s5-supplier-liberation.ts",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@hoppiness/shared": "*",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.7.0",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.38.3",
    "express": "^4.21.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "socket.io": "^4.8.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.16.5",
    "@types/node-cron": "^3.0.11",
    "drizzle-kit": "^0.30.4",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}
