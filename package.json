{
  "name": "hoppiness-hub",
  "private": true,
  "version": "0.0.1",
  "workspaces": [
    "packages/shared",
    "packages/backend",
    "packages/frontend"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "npm run dev -w @hoppiness/frontend",
    "dev:backend": "npm run dev -w @hoppiness/backend",
    "build": "npm run build -w @hoppiness/shared && npm run build -w @hoppiness/backend && npm run build -w @hoppiness/frontend",
    "db:migrate": "npm run db:migrate -w @hoppiness/backend",
    "db:generate": "npm run db:generate -w @hoppiness/backend",
    "db:seed": "npm run db:seed -w @hoppiness/backend"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
