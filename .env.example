# ============================================================================
# Hoppiness Hub — Local Monorepo Environment Variables
# ============================================================================
# Copy this to .env and adjust values as needed.
# For local development, defaults work out of the box.
# ============================================================================

# Backend
PORT=3001
NODE_ENV=development
JWT_SECRET=hoppiness-local-dev-secret-change-in-production
JWT_REFRESH_SECRET=hoppiness-refresh-secret-change-in-production

# Frontend
VITE_APP_URL=http://localhost:5173
VITE_APP_VERSION=0.0.1
VITE_APP_BUILD_DATE=2026-04-23

# External services (optional — work when you have internet)
# VITE_SENTRY_DSN=
# VITE_TURNSTILE_SITE_KEY=
# VITE_VAPID_PUBLIC_KEY=
# GOOGLE_MAPS_API_KEY=
# RESEND_API_KEY=
# MP_ACCESS_TOKEN=
# AFIP_CUIT=
# AFIP_CERT_BASE64=
# AFIP_KEY_BASE64=
# AFIP_ENVIRONMENT=testing
